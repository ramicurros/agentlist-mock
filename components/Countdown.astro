---
// MeetingBanner.astro
// Props: set your next meeting date/time here or pass via props
interface Props {
  meetingDate?: string; // ISO string, e.g. "2026-03-15T10:00:00"
  meetingsPageUrl?: string;
}

const {
  meetingDate = "2026-03-15T10:00:00",
  meetingsPageUrl = "/meetings",
} = Astro.props;
---

<section id="meeting-banner">
  <div class="banner-inner">
    <!-- Left accent bar -->
    <div class="accent-bar"></div>

    <div class="banner-content">
      <span class="cs-topper banner-topper">Upcoming Event</span>

      <div class="banner-body">
        <div class="banner-text-group">
          <h2 class="cs-title banner-title">Presential Meeting: [US Base Name]</h2>
          <p class="cs-text banner-desc">
            Meet with top-tier relocation experts in person and start planning your move today.
          </p>
        </div>

        <div class="banner-right">
          <!-- Countdown -->
          <div class="countdown" aria-label="Countdown to meeting">
            <div class="countdown-unit">
              <span class="countdown-num" id="days">--</span>
              <span class="countdown-label">Days</span>
            </div>
            <span class="countdown-sep">:</span>
            <div class="countdown-unit">
              <span class="countdown-num" id="hours">--</span>
              <span class="countdown-label">Hours</span>
            </div>
            <span class="countdown-sep">:</span>
            <div class="countdown-unit">
              <span class="countdown-num" id="minutes">--</span>
              <span class="countdown-label">Min</span>
            </div>
            <span class="countdown-sep">:</span>
            <div class="countdown-unit">
              <span class="countdown-num" id="seconds">--</span>
              <span class="countdown-label">Sec</span>
            </div>
          </div>

          <a href={meetingsPageUrl} class="banner-btn">
            Reserve Your Spot
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ meetingDate }}>
  const target = new Date(meetingDate).getTime();

  function pad(n) {
    return String(n).padStart(2, "0");
  }

  function tick() {
    const now = Date.now();
    const diff = target - now;

    if (diff <= 0) {
      document.getElementById("days").textContent = "00";
      document.getElementById("hours").textContent = "00";
      document.getElementById("minutes").textContent = "00";
      document.getElementById("seconds").textContent = "00";
      return;
    }

    const days    = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours   = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((diff % (1000 * 60)) / 1000);

    document.getElementById("days").textContent    = pad(days);
    document.getElementById("hours").textContent   = pad(hours);
    document.getElementById("minutes").textContent = pad(minutes);
    document.getElementById("seconds").textContent = pad(seconds);
  }

  tick();
  setInterval(tick, 1000);
</script>

<style>
  /* =============================================
     BANNER SECTION
  ============================================= */
  #meeting-banner {
    width: 100%;
    /* --headerColor is #1a1a1a — the darkest token available */
    background-color: var(--headerColor);
    padding: clamp(2rem, 4vw, 3rem) 1rem;
    position: relative;
    overflow: hidden;
  }

  /* Decorative rings — tinted from existing palette vars */
  #meeting-banner::before {
    content: "";
    position: absolute;
    right: -8rem;
    top: 50%;
    transform: translateY(-50%);
    width: 28rem;
    height: 28rem;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--primary) 10%, transparent);
    pointer-events: none;
  }

  #meeting-banner::after {
    content: "";
    position: absolute;
    right: -5rem;
    top: 50%;
    transform: translateY(-50%);
    width: 20rem;
    height: 20rem;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--primaryLight) 8%, transparent);
    pointer-events: none;
  }

  .banner-inner {
    max-width: 75rem;
    margin: 0 auto;
    display: flex;
    align-items: stretch;
    gap: 2rem;
    position: relative;
    z-index: 1;
  }

  /* Left accent bar — primary → secondary gradient */
  .accent-bar {
    width: 4px;
    min-height: 100%;
    border-radius: 2px;
    background: linear-gradient(180deg, var(--primary) 0%, var(--secondary) 100%);
    flex-shrink: 0;
  }

  .banner-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* On dark bg, shift topper to the lighter brand token */
  .banner-topper {
    color: var(--secondaryLight);
  }

  .banner-body {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .banner-text-group {
    flex: 1;
    min-width: 16rem;
  }

  .banner-title {
    color: var(--bodyTextColorWhite);
    margin-bottom: 0.5rem;
    /* Pull the shared header size token */
    font-size: var(--headerFontSize);
  }

  .banner-desc {
    /* Soften the white text token instead of inventing a new color */
    color: color-mix(in srgb, var(--bodyTextColorWhite) 65%, transparent);
    max-width: 40.625rem; /* same max-width as .cs-text */
    font-weight: 400;
  }

  /* =============================================
     RIGHT SIDE: COUNTDOWN + CTA
  ============================================= */
  .banner-right {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    flex-shrink: 0;
  }

  /* COUNTDOWN */
  .countdown {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .countdown-unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    min-width: 3.5rem;
  }

  .countdown-num {
    /* Shares the header size scale */
    font-size: var(--headerFontSize);
    font-weight: 900;
    line-height: 1;
    color: var(--bodyTextColorWhite);
    background: color-mix(in srgb, var(--bodyTextColorWhite) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--bodyTextColorWhite) 10%, transparent);
    border-radius: 6px;
    padding: 0.4rem 0.75rem;
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
    transition: transform 0.15s ease, opacity 0.15s ease;
    display: block;
    text-align: center;
  }

  .countdown-label {
    /* Reuse the topper size token — it's already the smallest text scale */
    font-size: var(--topperFontSize);
    text-transform: uppercase;
    /* Match .cs-topper letter-spacing */
    letter-spacing: 0.1em;
    color: color-mix(in srgb, var(--bodyTextColorWhite) 45%, transparent);
    font-weight: 700;
  }

  .countdown-sep {
    font-size: var(--headerFontSize);
    font-weight: 900;
    color: var(--primary);
    margin-bottom: 1.6rem;
    line-height: 1;
  }

  /* CTA BUTTON */
  .banner-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--primary);
    /* White text — use the defined white token */
    color: var(--bodyTextColorWhite);
    /* Body font size token */
    font-size: var(--bodyFontSize);
    font-weight: 700;
    text-decoration: none;
    padding: 0.75rem 1.75rem;
    border-radius: 4px;
    white-space: nowrap;
    position: relative;
    overflow: hidden;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .banner-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, color-mix(in srgb, var(--bodyTextColorWhite) 15%, transparent) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .banner-btn:hover {
    /* Darken --primary slightly instead of hardcoding a hex */
    background: color-mix(in srgb, var(--primary) 85%, black);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px color-mix(in srgb, var(--primary) 45%, transparent);
  }

  .banner-btn:hover::before {
    opacity: 1;
  }

  .banner-btn:active {
    transform: translateY(0);
  }

  .banner-btn svg {
    transition: transform 0.2s ease;
  }

  .banner-btn:hover svg {
    transform: translateX(4px);
  }

  /* =============================================
     RESPONSIVE
  ============================================= */
  @media (max-width: 768px) {
    .banner-body {
      flex-direction: column;
      align-items: flex-start;
    }

    .banner-right {
      width: 100%;
      align-items: flex-start;
    }

    .banner-btn {
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .countdown-unit {
      min-width: 2.75rem;
    }

    .countdown-num {
      padding: 0.35rem 0.5rem;
    }
  }
</style>